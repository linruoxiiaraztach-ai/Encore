rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── avatars/ ──────────────────────────────────────────────
    // Publicly readable. Only the owner can upload/update their own avatar.
    // Expected path: avatars/{userId}/{filename}
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024          // 2 MB max
                   && request.resource.contentType.matches('image/.*'); // images only
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── item-photos/ ──────────────────────────────────────────
    // Publicly readable. Only the uploader (matched by folder = uid) can write.
    // Expected path: item-photos/{userId}/{filename}
    match /item-photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024         // 10 MB max
                   && request.resource.contentType.matches('image/.*'); // images only
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

  }
}
